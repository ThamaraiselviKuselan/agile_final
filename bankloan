package com.example;

import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;

class AppTest {

    App loan = new App();

    @Test
    void testEligibleApplicant() {
        assertTrue(loan.isEligible(30, 40000, 750));
    }

    @Test
    void testNotEligibleDueToAge() {
        assertFalse(loan.isEligible(18, 40000, 750));
    }

    @Test
    void testNotEligibleDueToIncome() {
        assertFalse(loan.isEligible(30, 20000, 750));
    }

    @Test
    void testNotEligibleDueToCreditScore() {
        assertFalse(loan.isEligible(30, 40000, 650));
    }

    @Test
    void testBoundaryCase() {
        assertTrue(loan.isEligible(21, 25000, 700));
    }
}
