package com.example;

import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;

class AppTest {

    App scholarship = new App();

    @Test
    void testEligibleStudent() {
        assertTrue(scholarship.isEligible(85.0, 150000));
    }

    @Test
    void testNotEligibleDueToLowPercentage() {
        assertFalse(scholarship.isEligible(70.0, 150000));
    }

    @Test
    void testNotEligibleDueToHighIncome() {
        assertFalse(scholarship.isEligible(85.0, 250000));
    }

    @Test
    void testBoundaryCase() {
        assertTrue(scholarship.isEligible(75.0, 200000));
    }
}
