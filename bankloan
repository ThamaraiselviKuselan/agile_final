package com.example;

public class App {

    public boolean isEligible(int age, double income, int creditScore) {
        return age >= 21 && income >= 25000 && creditScore >= 700;
    }

    public static void main(String[] args) {
        App loan = new App();

        int age = 30;
        double income = 40000;
        int creditScore = 750;

        boolean eligible = loan.isEligible(age, income, creditScore);

        System.out.println("Age: " + age);
        System.out.println("Income: " + income);
        System.out.println("Credit Score: " + creditScore);
        System.out.println("Loan Eligible: " + eligible);
    }
}

