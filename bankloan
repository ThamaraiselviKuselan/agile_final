package com.example;

public class App {

    public boolean isEligible(double percentage, double familyIncome) {
        return percentage >= 75.0 && familyIncome <= 200000;
    }

    public static void main(String[] args) {
        App scholarship = new App();

        double percentage = 82.5;
        double familyIncome = 150000;

        boolean eligible = scholarship.isEligible(percentage, familyIncome);

        System.out.println("Percentage: " + percentage);
        System.out.println("Family Income: " + familyIncome);
        System.out.println("Scholarship Eligible: " + eligible);
    }
}

