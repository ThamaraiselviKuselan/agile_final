package com.example;

import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;

class AppTest {

    App employee = new App();

    @Test
    void testCalculateNetSalary() {
        assertEquals(33000, employee.calculateNetSalary(30000, 5000, 2000), 0.01);
    }

    @Test
    void testZeroBonus() {
        assertEquals(28000, employee.calculateNetSalary(30000, 0, 2000), 0.01);
    }

    @Test
    void testZeroDeductions() {
        assertEquals(35000, employee.calculateNetSalary(30000, 5000, 0), 0.01);
    }

    @Test
    void testNegativeSalary() {
        assertThrows(IllegalArgumentException.class, () -> employee.calculateNetSalary(-30000, 5000, 2000));
    }

    @Test
    void testNegativeBonus() {
        assertThrows(IllegalArgumentException.class, () -> employee.calculateNetSalary(30000, -5000, 2000));
    }

    @Test
    void testNegativeDeductions() {
        assertThrows(IllegalArgumentException.class, () -> employee.calculateNetSalary(30000, 5000, -2000));
    }
}
