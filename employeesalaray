package com.example;

public class App {

    public double calculateNetSalary(double basicSalary, double bonus, double deductions) {
        if (basicSalary < 0 || bonus < 0 || deductions < 0) {
            throw new IllegalArgumentException("Salary values cannot be negative");
        }
        return basicSalary + bonus - deductions;
    }

    public static void main(String[] args) {
        App employee = new App();

        double basicSalary = 30000;
        double bonus = 5000;
        double deductions = 2000;

        double netSalary = employee.calculateNetSalary(basicSalary, bonus, deductions);

        System.out.println("Basic Salary: " + basicSalary);
        System.out.println("Bonus: " + bonus);
        System.out.println("Deductions: " + deductions);
        System.out.println("Net Salary: " + netSalary);
    }
}

